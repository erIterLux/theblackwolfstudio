rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) { return signedIn() && request.auth.uid == userId; }

    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'email', 'phone', 'interest', 'message', 'createdAt', 'status', 'source'
      ])
      && request.resource.data.name is string
      && request.resource.data.email is string
      && request.resource.data.interest is string
      && request.resource.data.status == 'new';
      allow read, update, delete: if false;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /users/{userId}/wolfGuideConversations/{conversationId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/wolfGuideConversations/{conversationId}/messages/{messageId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }


    match /memberships/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /stripeEvents/{eventId} { allow read, write: if false; }
    match /wolfGuideUsage/{userId} { allow read, write: if false; }
  }
}
